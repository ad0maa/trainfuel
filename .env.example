# ── Database ────────────────────────────────────────────────────────────────
# Local dev Postgres runs via Homebrew (`brew services start postgresql@17`).
# Create the role/databases once with:
#   createuser -s trainfuel && psql postgres -c "ALTER ROLE trainfuel WITH PASSWORD 'trainfuel'"
#   createdb -O trainfuel trainfuel_dev && createdb -O trainfuel trainfuel_test
DATABASE_URL=postgres://trainfuel:trainfuel@localhost:5432/trainfuel_dev
TEST_DATABASE_URL=postgres://trainfuel:trainfuel@localhost:5432/trainfuel_test

# PRISMA_HIDE_UPDATE_MESSAGE=true
# LOG_LEVEL=trace

# ── App secrets ─────────────────────────────────────────────────────────────
# Signs/verifies the app's own outbound webhook payloads (e.g. scheduled jobs
# invoking api-side functions). Change for production.
WEBHOOK_SECRET=

# Encrypts/decrypts dbAuth session cookies. Generate with:
#   yarn cedar generate secret
SESSION_SECRET=

# 32-byte (base64) key used to encrypt IntegrationAccount tokens at rest
# (AES-256-GCM, see api/src/lib/crypto.ts). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# HMAC secret for signing/verifying mobile bearer tokens (see
# api/src/lib/mobileAuthToken.ts — SPEC.md §2's dbAuth-cookie fallback for
# the Expo app). Any random string works; generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MOBILE_AUTH_SECRET=

# ── Strava (§4.1) ───────────────────────────────────────────────────────────
# Register an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# The web app's own OAuth callback route — it reads ?code= and calls the
# connectStrava mutation. Same pattern as GOOGLE_OAUTH_REDIRECT_URI below,
# not a REST endpoint on the API side.
STRAVA_OAUTH_REDIRECT_URI=http://localhost:8910/settings
# Shared secret you choose; used to validate the webhook subscription challenge.
STRAVA_WEBHOOK_VERIFY_TOKEN=
# Public HTTPS URL Strava can reach in dev (e.g. via `cloudflared tunnel` /
# `ngrok`), pointed at this app's stravaWebhook function
# (<url>/api/stravaWebhook per cedar.toml's web.apiUrl).
STRAVA_WEBHOOK_CALLBACK_URL=

# ── Google Calendar (§4.3) ──────────────────────────────────────────────────
# Google Cloud project + OAuth consent screen ("testing" publish status is fine
# for personal use). Enable the Calendar API and create OAuth 2.0 credentials at
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8910/settings/integrations/google/callback

# ── Hevy (§4.2) ──────────────────────────────────────────────────────────────
# No env var: the Hevy personal API key (requires Hevy Pro) is entered by the
# user in Settings and stored encrypted in IntegrationAccount.apiKey.

# ── Open Food Facts (§4.4) ───────────────────────────────────────────────────
# OFF requires a descriptive User-Agent on all requests.
OFF_USER_AGENT=TrainFuel/1.0 (contact: you@example.com)

# ── USDA FDC (§4.4, optional in v1) ──────────────────────────────────────────
# https://fdc.nal.usda.gov/api-key-signup
USDA_FDC_API_KEY=
